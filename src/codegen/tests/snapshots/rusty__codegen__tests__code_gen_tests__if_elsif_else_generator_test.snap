; ModuleID = '<internal>'
source_filename = "<internal>"
target datalayout = "[filtered]"
target triple = "[filtered]"

%prg = type { i32, i32, i32, i32, i8, i8, i8 }

@prg_instance = global %prg zeroinitializer

define void @prg(ptr %0) {
entry:
  %x = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 0
  %y = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 1
  %z = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 2
  %u = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 3
  %b1 = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 4
  %b2 = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 5
  %b3 = getelementptr inbounds nuw %prg, ptr %0, i32 0, i32 6
  %load_b1 = load i8, ptr %b1, align [filtered]
  %1 = icmp ne i8 %load_b1, 0
  br i1 %1, label %condition_body, label %else

condition_body:                                   ; preds = %entry
  %load_x = load i32, ptr %x, align [filtered]
  br label %continue

else:                                             ; preds = %entry
  %load_b2 = load i8, ptr %b2, align [filtered]
  %2 = icmp ne i8 %load_b2, 0
  br i1 %2, label %condition_body3, label %else1

continue:                                         ; preds = %continue2, %condition_body
  ret void

condition_body3:                                  ; preds = %else
  %load_y = load i32, ptr %y, align [filtered]
  br label %continue2

else1:                                            ; preds = %else
  %load_b3 = load i8, ptr %b3, align [filtered]
  %3 = icmp ne i8 %load_b3, 0
  br i1 %3, label %condition_body6, label %else4

continue2:                                        ; preds = %continue5, %condition_body3
  br label %continue

condition_body6:                                  ; preds = %else1
  %load_z = load i32, ptr %z, align [filtered]
  br label %continue5

else4:                                            ; preds = %else1
  %load_u = load i32, ptr %u, align [filtered]
  br label %continue5

continue5:                                        ; preds = %else4, %condition_body6
  br label %continue2
}
