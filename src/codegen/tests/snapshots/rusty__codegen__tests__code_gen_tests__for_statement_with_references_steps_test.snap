continue:                                         ; preds = %condition_body14, %condition_body9, %condition_check
  ret void

condition_body:                                   ; preds = %while_body
  %load_x = load i32, ptr %x, align [filtered]
  %load_step2 = load i32, ptr %step, align [filtered]
  %tmpVar3 = add i32 %load_x, %load_step2
  store i32 %tmpVar3, ptr %x, align [filtered]
  br label %continue1

continue1:                                        ; preds = %condition_body, %while_body
  store i8 1, ptr %ran_once_0, align [filtered]
  %load_is_incrementing_0 = load i8, ptr %is_incrementing_0, align [filtered]
  %3 = icmp ne i8 %load_is_incrementing_0, 0
  br i1 %3, label %condition_body5, label %else

condition_body5:                                  ; preds = %continue1
  %load_x7 = load i32, ptr %x, align [filtered]
  %load_z = load i32, ptr %z, align [filtered]
  %tmpVar8 = icmp sgt i32 %load_x7, %load_z
  %4 = zext i1 %tmpVar8 to i8
  %5 = icmp ne i8 %4, 0
  br i1 %5, label %condition_body9, label %continue6

else:                                             ; preds = %continue1
  %load_x11 = load i32, ptr %x, align [filtered]
  %load_z12 = load i32, ptr %z, align [filtered]
  %tmpVar13 = icmp slt i32 %load_x11, %load_z12
  %6 = zext i1 %tmpVar13 to i8
  %7 = icmp ne i8 %6, 0
  br i1 %7, label %condition_body14, label %continue10

continue4:                                        ; preds = %continue10, %continue6
  %load_x16 = load i32, ptr %x, align [filtered]
  br label %condition_check

condition_body9:                                  ; preds = %condition_body5
  br label %continue

buffer_block:                                     ; No predecessors!
  br label %continue6

continue6:                                        ; preds = %buffer_block, %condition_body5
  br label %continue4

condition_body14:                                 ; preds = %else
  br label %continue

buffer_block15:                                   ; No predecessors!
