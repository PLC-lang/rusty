define i32 @myFunc() !dbg !4 {
entry:
  %myFunc = alloca i32, align [filtered]
    #dbg_declare(ptr %myFunc, !8, !DIExpression(), !10)
  store i32 0, ptr %myFunc, align [filtered]
  %load_myFunc = load i32, ptr %myFunc, align [filtered], !dbg !11
  %myFunc_ret = load i32, ptr %myFunc, align [filtered], !dbg !12
  ret i32 %myFunc_ret, !dbg !12
}

!llvm.module.flags = !{!0, !1}
!llvm.dbg.cu = !{!2}

!0 = !{i32 2, !"Dwarf Version", i32 5}
