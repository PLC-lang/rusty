  %this = alloca ptr, align [filtered]
  store ptr %0, ptr %this, align [filtered]
  %x = getelementptr inbounds nuw %fb, ptr %0, i32 0, i32 0
  %load_x = load i32, ptr %x, align [filtered], !dbg !25
  %tmpVar = add i32 %load_x, 2, !dbg !25
  store i32 %tmpVar, ptr %x, align [filtered], !dbg !25
  ret void, !dbg !26
}

