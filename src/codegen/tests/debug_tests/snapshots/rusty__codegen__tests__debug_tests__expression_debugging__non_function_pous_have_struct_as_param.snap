define void @myProg(ptr %0) !dbg !11 {
entry:
    #dbg_declare(ptr %0, !15, !DIExpression(), !16)
  %x = getelementptr inbounds nuw %myProg, ptr %0, i32 0, i32 0
  %load_x = load i32, ptr %x, align [filtered], !dbg !16
