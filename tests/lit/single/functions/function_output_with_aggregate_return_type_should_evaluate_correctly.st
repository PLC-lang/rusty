// RUN: (%COMPILE %s && %RUN) | %CHECK %s
FUNCTION F : STRING
    VAR_INPUT
        Key : STRING[1023];
    END_VAR
    VAR_OUTPUT
        Value : STRING[1023];
    END_VAR

    Value := '';
    F := 'returned';
END_FUNCTION

PROGRAM mainProg
    VAR
        MyString : STRING;          // too-small caller buffer
        MyInt    : INT  := 1234;    // guards
        MyGuard  : DINT := 24681357;
        retString : STRING;
    END_VAR
    retString := F('key', MyString);

    // CHECK: ret=returned my_int=1234 my_guard=24681357 value_prefix=AAAAAAAA
    printf('ret=%.8s my_int=%d my_guard=%d value_prefix=%.8s$N', retString, MyInt, MyGuard, MyString);
END_PROGRAM

FUNCTION main : DINT
    mainProg();
END_FUNCTION
