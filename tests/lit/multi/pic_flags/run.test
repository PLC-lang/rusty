// === Part 1: Compile multi-file objects with PIC and no-PIC, link to executables ===

// Compile PIC object and link to executable with cc
RUN: %COMPILE -c --fpic %S/main.st %S/helper.st && mv %T/%basename_t.out %T/pic_merged.o
RUN: cc %T/pic_merged.o -o %T/cc_pic_exe && %T/cc_pic_exe | FileCheck-21 --check-prefix=EXE %s

// Compile no-PIC object and link to executable with cc -no-pie
RUN: %COMPILE -c --fno-pic %S/main.st %S/helper.st && mv %T/%basename_t.out %T/nopic_merged.o
RUN: cc -no-pie %T/nopic_merged.o -o %T/cc_nopic_exe && %T/cc_nopic_exe | FileCheck-21 --check-prefix=EXE %s

// Link PIC object to executable with plc
RUN: %COMPILE %T/pic_merged.o && %RUN | FileCheck-21 --check-prefix=EXE %s

// Link no-PIC object to executable with plc (auto -no-pie via --fno-pic)
RUN: %COMPILE --fno-pic %T/nopic_merged.o && %RUN | FileCheck-21 --check-prefix=EXE %s

// === Part 2: Build PIC shared library, link from C with -l ===

// Build PIC shared library from helper.st only
RUN: %COMPILE --shared --fpic %S/helper.st && mv %T/%basename_t.out %T/libhelper_pic.so

// Compile and link C runner against the shared library using -l
RUN: cc %S/c_runner.c -L%T -lhelper_pic -o %T/c_linked_exe
RUN: LD_LIBRARY_PATH=%T %T/c_linked_exe | FileCheck-21 --check-prefix=EXE %s

// === Part 3: Build no-PIC static executable (no shared lib for no-PIC on x86_64) ===

// Build static executable directly with --fno-pic
RUN: %COMPILE --fno-pic %S/main.st %S/helper.st && %RUN | FileCheck-21 --check-prefix=EXE %s

// === Part 4: dlopen test against PIC shared library ===

// Build dlopen-based runner
RUN: cc %S/so_runner.c -ldl -o %T/so_runner

// Load PIC shared lib via dlopen and call helper()/doubler()
RUN: LD_LIBRARY_PATH=%T %T/so_runner %T/libhelper_pic.so | FileCheck-21 --check-prefix=EXE %s

// === Part 5: Deprecated --pic still works (maps to --shared --fpic) ===

RUN: %COMPILE --pic %S/helper.st && mv %T/%basename_t.out %T/libhelper_compat.so
RUN: LD_LIBRARY_PATH=%T %T/so_runner %T/libhelper_compat.so | FileCheck-21 --check-prefix=EXE %s

// EXE: 42
// EXE-NEXT: 84
