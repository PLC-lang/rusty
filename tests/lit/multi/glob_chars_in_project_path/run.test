// Regression test: a project whose directory name contains characters that are
// special in glob syntax (`[`, `]`) must still compile, link and run. The
// project loader used to pass every source path straight to glob(), so a
// bracketed directory name was parsed as a character class, matched no files,
// and the sources were silently dropped. See compiler/plc_project/src/project.rs
// (`resolve_file_paths`) and its unit tests.
//
// The paths are quoted so the *test* shell does not glob-expand them; the point
// is to exercise plc's own path resolution, not bash's.

// Bracketed directory: `main.st` is a literal source and `src/*.st` is a glob,
// both resolved relative to the bracketed project directory.
RUN: %COMPILE build "%S/[---test---]/plc.json" && %RUN | %CHECK "%S/[---test---]/main.st"

// Directory name mixing spaces, parentheses and brackets.
RUN: %COMPILE build "%S/weird [v2] (debug)/plc.json" && %RUN | %CHECK "%S/weird [v2] (debug)/main.st"
