FUNCTION_BLOCK Shape
VAR
END_VAR
    METHOD Draw
    END_METHOD
END_FUNCTION_BLOCK

FUNCTION_BLOCK Rectangle EXTENDS Shape
VAR
    x : DINT;
    y : DINT;
END_VAR
    METHOD FB_INIT
    END_METHOD

    METHOD Draw
    END_METHOD
END_FUNCTION_BLOCK

FUNCTION_BLOCK Square EXTENDS Shape
VAR
    x : DINT;
END_VAR
    PROPERTY_GET size: DINT END_GET
    PROPERTY_SET size: DINT END_SET

    METHOD FB_INIT
    END_METHOD

    METHOD Draw
    END_METHOD
END_FUNCTION_BLOCK

ACTIONS Square
    ACTION DrawAction END_ACTION
END_ACTIONS

FUNCTION DrawRectangle
VAR_INPUT
    x : DINT;
    y : DINT;
END_VAR
END_FUNCTION
